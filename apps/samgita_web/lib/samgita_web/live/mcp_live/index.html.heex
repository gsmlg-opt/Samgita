<div class="max-w-7xl mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="text-3xl font-bold text-on-surface">MCP Server Management</h1>
      <p class="text-on-surface-variant mt-2">Configure Model Context Protocol servers</p>
    </div>
    <div class="flex gap-3">
      <.dm_btn variant="outline" phx-click="refresh">Refresh</.dm_btn>
      <.link navigate={~p"/"}>
        <.dm_btn variant="ghost">← Back to Dashboard</.dm_btn>
      </.link>
    </div>
  </div>

  <.dm_card body_class="" variant="bordered" class="p-4 mb-6 bg-primary-container/20">
    <div class="flex items-start gap-3">
      <.dm_mdi name="information-outline" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
      <div class="flex-1">
        <p class="font-medium text-on-surface">MCP Configuration</p>
        <p class="text-sm text-on-surface-variant mt-1">
          MCP servers are configured in
          <code class="bg-surface-container px-1 rounded">~/.claude/mcp.json</code>
        </p>
        <div class="mt-3">
          <.link navigate={~p"/references/mcp-integration.md"}>
            <.dm_btn variant="outline" size="sm">View MCP Integration Guide</.dm_btn>
          </.link>
        </div>
      </div>
    </div>
  </.dm_card>

  <div class="grid gap-4">
    <.dm_card :for={server <- @servers} body_class="" variant="bordered" class="p-6">
      <div class="flex items-start justify-between">
        <div class="flex-1">
          <div class="flex items-center gap-3">
            <h3 class="text-lg font-semibold text-on-surface">{server.name}</h3>
            <.dm_badge variant={status_badge_color(server.status)}>{server.status}</.dm_badge>
          </div>
          <p class="text-sm text-on-surface-variant mt-2">{server.description}</p>
          <div class="flex gap-2 mt-3">
            <.dm_badge :for={capability <- server.capabilities} variant="secondary">
              {capability}
            </.dm_badge>
          </div>
        </div>
      </div>
    </.dm_card>
  </div>

  <div :if={@servers == []} class="text-center py-16 text-on-surface-variant">
    <p class="text-lg">No MCP servers configured.</p>
    <p class="mt-2">
      Add servers to
      <code class="bg-surface-container px-2 py-1 rounded">~/.claude/mcp.json</code>
    </p>
  </div>
</div>

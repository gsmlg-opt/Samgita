<div class="max-w-7xl mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="text-3xl font-bold text-on-surface">Claude Skills</h1>
      <p class="text-on-surface-variant mt-2">Manage Claude Code skills and extensions</p>
    </div>
    <div class="flex gap-3">
      <.dm_btn variant="outline" phx-click="refresh">Refresh</.dm_btn>
      <.link navigate={~p"/"}>
        <.dm_btn variant="ghost">← Back to Dashboard</.dm_btn>
      </.link>
    </div>
  </div>

  <.dm_card body_class="" variant="bordered" class="p-4 mb-6 bg-primary-container/20">
    <div class="flex items-start gap-3">
      <.dm_mdi name="information-outline" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
      <div class="flex-1">
        <p class="font-medium text-on-surface">Skills Directory</p>
        <p class="text-sm text-on-surface-variant mt-1">
          Skills are located in
          <code class="bg-surface-container px-1 rounded">~/.claude/skills/</code>
        </p>
        <div class="mt-3 flex flex-wrap gap-2">
          <.link navigate={~p"/references/quality-control.md"}>
            <.dm_btn variant="outline" size="sm">Quality Control Patterns</.dm_btn>
          </.link>
          <.link navigate={~p"/references/openai-patterns.md"}>
            <.dm_btn variant="outline" size="sm">OpenAI Patterns</.dm_btn>
          </.link>
        </div>
      </div>
    </div>
  </.dm_card>

  <div class="grid gap-4">
    <.dm_card
      :for={skill <- @skills}
      body_class=""
      variant="bordered"
      class="p-6 hover:shadow-md transition-shadow"
    >
      <div class="flex items-start gap-4">
        {status_icon(skill.status)}
        <div class="flex-1">
          <div class="flex items-start justify-between">
            <div>
              <h3 class="text-lg font-semibold text-on-surface font-mono">/{skill.name}</h3>
              <p class="text-sm text-on-surface-variant mt-1">{skill.description}</p>
            </div>
            <.dm_badge variant={category_badge_color(skill.category)}>{skill.category}</.dm_badge>
          </div>
        </div>
      </div>
    </.dm_card>
  </div>

  <div :if={@skills == []} class="text-center py-16 text-on-surface-variant">
    <p class="text-lg">No skills found.</p>
    <p class="mt-2">
      Add skills to <code class="bg-surface-container px-2 py-1 rounded">~/.claude/skills/</code>
    </p>
  </div>
</div>

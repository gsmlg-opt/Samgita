<div class="max-w-7xl mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-on-surface">Samgita Dashboard</h1>
    <.link navigate={~p"/projects/new"}><.dm_btn variant="primary">New Project</.dm_btn></.link>
  </div>

  <%!-- Management Cards --%>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <.link navigate={~p"/agents"} class="block">
      <.dm_card variant="bordered" class="p-6 hover:shadow-md transition-shadow h-full">
        <div class="flex items-center gap-3 mb-2">
          <div class="p-2 bg-tertiary-container rounded-lg">
            <.dm_mdi name="robot" class="w-6 h-6 text-on-tertiary-container" />
          </div>
          <h3 class="text-lg font-semibold text-on-surface">Agents</h3>
        </div>
        <p class="text-sm text-on-surface-variant">View and manage agent definitions</p>
      </.dm_card>
    </.link>

    <.link navigate={~p"/mcp"} class="block">
      <.dm_card variant="bordered" class="p-6 hover:shadow-md transition-shadow h-full">
        <div class="flex items-center gap-3 mb-2">
          <div class="p-2 bg-primary-container rounded-lg">
            <.dm_mdi name="server-network" class="w-6 h-6 text-on-primary-container" />
          </div>
          <h3 class="text-lg font-semibold text-on-surface">MCP Servers</h3>
        </div>
        <p class="text-sm text-on-surface-variant">Configure Model Context Protocol servers</p>
      </.dm_card>
    </.link>

    <.link navigate={~p"/skills"} class="block">
      <.dm_card variant="bordered" class="p-6 hover:shadow-md transition-shadow h-full">
        <div class="flex items-center gap-3 mb-2">
          <div class="p-2 bg-secondary-container rounded-lg">
            <.dm_mdi name="book-open-variant" class="w-6 h-6 text-on-secondary-container" />
          </div>
          <h3 class="text-lg font-semibold text-on-surface">Skills</h3>
        </div>
        <p class="text-sm text-on-surface-variant">Manage Claude Code skills</p>
      </.dm_card>
    </.link>

    <.link navigate={~p"/references"} class="block">
      <.dm_card variant="bordered" class="p-6 hover:shadow-md transition-shadow h-full">
        <div class="flex items-center gap-3 mb-2">
          <div class="p-2 bg-tertiary-container rounded-lg">
            <.dm_mdi name="file-document-outline" class="w-6 h-6 text-on-tertiary-container" />
          </div>
          <h3 class="text-lg font-semibold text-on-surface">References</h3>
        </div>
        <p class="text-sm text-on-surface-variant">Loki Mode patterns and research</p>
      </.dm_card>
    </.link>
  </div>

  <h2 class="text-2xl font-bold text-on-surface mb-4">Projects</h2>

  <div :if={@projects == []} class="text-center py-16 text-on-surface-variant">
    <p class="text-lg">No projects yet.</p>
    <p class="mt-2">Create your first project to get started.</p>
  </div>

  <div class="grid gap-4">
    <.link :for={project <- @projects} navigate={~p"/projects/#{project}"} class="block">
      <.dm_card variant="bordered" class="p-6 hover:shadow-md transition-shadow">
        <div class="flex justify-between items-start">
          <div>
            <h2 class="text-xl font-semibold text-on-surface">{project.name}</h2>
            <p class="text-sm text-on-surface-variant mt-1">{project.git_url}</p>
          </div>
          <div class="flex gap-2">
            <.dm_badge color={status_badge_color(project.status)}>{project.status}</.dm_badge>
            <.dm_badge color="secondary">{project.phase}</.dm_badge>
          </div>
        </div>
        <% stats = Map.get(@project_stats, project.id, %{}) %>
        <div :if={total_tasks(stats) > 0} class="mt-3 flex items-center gap-4 text-xs text-on-surface-variant">
          <span class="text-success">{task_stat(stats, :completed)} done</span>
          <span class="text-primary">{task_stat(stats, :running)} running</span>
          <span class="text-warning">{task_stat(stats, :pending)} pending</span>
          <span :if={task_stat(stats, :failed) > 0} class="text-error">
            {task_stat(stats, :failed)} failed
          </span>
          <span :if={task_stat(stats, :dead_letter) > 0} class="text-on-surface-variant">
            {task_stat(stats, :dead_letter)} dead
          </span>
          <div class="flex-1 h-1.5 bg-surface-container rounded-full overflow-hidden flex">
            <div class="bg-success" style={"width: #{if total_tasks(stats) > 0, do: task_stat(stats, :completed) / total_tasks(stats) * 100, else: 0}%"}></div>
            <div class="bg-primary" style={"width: #{if total_tasks(stats) > 0, do: task_stat(stats, :running) / total_tasks(stats) * 100, else: 0}%"}></div>
            <div class="bg-error" style={"width: #{if total_tasks(stats) > 0, do: task_stat(stats, :failed) / total_tasks(stats) * 100, else: 0}%"}></div>
          </div>
        </div>
      </.dm_card>
    </.link>
  </div>
</div>

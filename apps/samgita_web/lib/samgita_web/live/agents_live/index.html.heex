<div class="max-w-7xl mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="text-3xl font-bold text-on-surface">Agent Definitions</h1>
      <p class="text-on-surface-variant mt-2">37 specialized agents across 7 swarms</p>
    </div>
    <.link navigate={~p"/"}><.dm_btn variant="ghost">← Back to Dashboard</.dm_btn></.link>
  </div>

  <%!-- Related References --%>
  <.dm_card body_class="" variant="bordered" class="p-4 mb-6 bg-primary-container/20">
    <div class="flex items-start gap-3">
      <.dm_mdi name="file-document-outline" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
      <div class="flex-1">
        <p class="text-sm font-medium text-on-surface mb-2">Related Documentation</p>
        <div class="flex flex-wrap gap-2">
          <.link navigate={~p"/references/agents.md"}><.dm_btn variant="outline" size="sm">Agent Type Definitions</.dm_btn></.link>
          <.link navigate={~p"/references/agent-types.md"}><.dm_btn variant="outline" size="sm">Agent Types Reference</.dm_btn></.link>
          <.link navigate={~p"/references/core-workflow.md"}><.dm_btn variant="outline" size="sm">RARV Workflow</.dm_btn></.link>
        </div>
      </div>
    </div>
  </.dm_card>

  <div :if={@selected_swarm} class="mb-6">
    <.dm_btn variant="ghost" size="sm" phx-click="clear_selection">← View all swarms</.dm_btn>
  </div>

  <div :if={is_nil(@selected_swarm)} class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <.dm_card
      :for={{swarm_name, agents} <- @agent_types}
      body_class=""
      variant="bordered"
      class="p-6 hover:shadow-md transition-shadow hover:bg-surface-container-high cursor-pointer text-left"
      phx-click="select_swarm"
      phx-value-swarm={swarm_name}
    >
      <div class="flex items-center justify-between mb-2">
        <h3 class="text-lg font-semibold text-on-surface">{swarm_name}</h3>
        <.dm_badge variant={swarm_badge_color(swarm_name)}>{length(agents)}</.dm_badge>
      </div>
      <p class="text-sm text-on-surface-variant">{length(agents)} agents</p>
    </.dm_card>
  </div>

  <div :if={@selected_swarm} class="space-y-4">
    <h2 class="text-2xl font-bold text-on-surface mb-4">{@selected_swarm}</h2>
    <div class="grid gap-4">
      <.dm_card body_class="" :for={agent <- @agent_types[@selected_swarm]} variant="bordered" class="hover:shadow-md transition-shadow">
        <div class="p-6">
          <div class="flex items-start justify-between">
            <div class="flex-1">
              <div class="flex items-center gap-3">
                <h3 class="text-lg font-semibold text-on-surface font-mono">{agent.name}</h3>
                <button
                  phx-click="toggle_agent"
                  phx-value-agent={agent.name}
                  class="text-on-surface-variant hover:text-on-surface transition-colors"
                  title={if expanded?(@expanded_agents, agent.name), do: "Collapse", else: "Expand"}
                >
                  <.dm_mdi name="chevron-down" class={"w-5 h-5 transition-transform #{if expanded?(@expanded_agents, agent.name), do: "rotate-180", else: ""}"} />
                </button>
              </div>
              <p class="text-sm text-on-surface-variant mt-2">{agent.description}</p>
            </div>
            <.dm_badge variant={swarm_badge_color(@selected_swarm)}>
              {@selected_swarm |> String.split(" ") |> hd()}
            </.dm_badge>
          </div>

          <div :if={expanded?(@expanded_agents, agent.name)} class="mt-4 pt-4 border-t border-outline space-y-4">
            <%!-- Agent Markdown --%>
            <div>
              <h4 class="text-sm font-semibold text-on-surface mb-2">Agent Definition (Markdown)</h4>
              <div class="bg-inverse-surface rounded-lg p-4 overflow-x-auto">
                <pre class="text-xs text-inverse-on-surface font-mono leading-relaxed"><%= agent_markdown(agent, @selected_swarm) %></pre>
              </div>
            </div>
            <%!-- Capabilities --%>
            <div>
              <h4 class="text-sm font-semibold text-on-surface mb-2">Capabilities</h4>
              <div class="bg-surface-container rounded-lg p-4">
                <ul class="space-y-1">
                  <li :for={capability <- agent.capabilities} class="text-sm text-on-surface flex items-start">
                    <span class="text-on-surface-variant mr-2">•</span>
                    <span>{capability}</span>
                  </li>
                </ul>
              </div>
            </div>
            <%!-- Task Types --%>
            <div>
              <h4 class="text-sm font-semibold text-on-surface mb-2">Task Types</h4>
              <div class="flex flex-wrap gap-2">
                <.dm_badge :for={task_type <- agent.task_types} variant="primary" class="font-mono">{task_type}</.dm_badge>
              </div>
            </div>
            <%!-- Quality Checks --%>
            <div>
              <h4 class="text-sm font-semibold text-on-surface mb-2">Quality Checks</h4>
              <div class="bg-secondary-container/30 rounded-lg p-4">
                <ul class="space-y-1">
                  <li :for={check <- agent.quality_checks} class="text-sm text-on-surface flex items-start">
                    <.dm_mdi name="check-circle" class="w-4 h-4 mr-2 mt-0.5 shrink-0 text-success" />
                    <span>{check}</span>
                  </li>
                </ul>
              </div>
            </div>
            <%!-- Model --%>
            <div :if={Map.get(agent, :model)}>
              <h4 class="text-sm font-semibold text-on-surface mb-2">Recommended Model</h4>
              <div class="bg-tertiary-container/30 border border-tertiary-container rounded-lg p-3">
                <span class="text-sm font-mono text-on-tertiary-container">{Map.get(agent, :model)}</span>
                <span class="text-xs text-on-tertiary-container/70 ml-2">(required for deep analysis)</span>
              </div>
            </div>
          </div>
        </div>
      </.dm_card>
    </div>
  </div>
</div>

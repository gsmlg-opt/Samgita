# Samgita Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# REQUIRED CONFIGURATION
# ============================================================================

# Database password for PostgreSQL
DB_PASSWORD=your_secure_password_here

# Phoenix secret key base (generate with: mix phx.gen.secret)
SECRET_KEY_BASE=your_secret_key_base_here

# Anthropic API key for embeddings (Voyage API)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Public hostname (for production deployment)
PHX_HOST=samgita.example.com

# ============================================================================
# OPTIONAL CONFIGURATION
# ============================================================================

# HTTP port (default: 3110)
HOST_PORT=3110

# Database connection pool sizes
POOL_SIZE=10
MEMORY_POOL_SIZE=5

# API Keys for REST API authentication (comma-separated)
# If empty, API has no authentication (suitable for localhost only)
SAMGITA_API_KEYS=

# Claude CLI command (default: claude)
CLAUDE_COMMAND=claude

# Workspace directory for agent operations
WORKSPACE_DIR=./workspace

# Erlang release cookie (for distributed Erlang clustering)
RELEASE_COOKIE=samgita_cluster_cookie_change_me

# DNS cluster query for auto-discovery (libcluster)
DNS_CLUSTER_QUERY=

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Uncomment for IPv6 support
# ECTO_IPV6=true

# ============================================================================
# PRODUCTION CHECKLIST
# ============================================================================
# Before deploying to production:
#
# [ ] Changed DB_PASSWORD to a strong, unique password
# [ ] Generated new SECRET_KEY_BASE (mix phx.gen.secret)
# [ ] Set ANTHROPIC_API_KEY with your actual key
# [ ] Set PHX_HOST to your production domain
# [ ] Set SAMGITA_API_KEYS for API authentication
# [ ] Changed RELEASE_COOKIE to a unique value
# [ ] Configured SSL/TLS (via nginx or Caddy)
# [ ] Set up firewall rules
# [ ] Configured backups
# [ ] Set up monitoring
